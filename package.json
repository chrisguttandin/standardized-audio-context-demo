{
    "author": "Christoph Guttandin",
    "bugs": {
        "url": "https://github.com/chrisguttandin/standardized-audio-context-demo/issues"
    },
    "config": {
        "commitizen": {
            "path": "cz-conventional-changelog"
        }
    },
    "dependencies": {
        "standardized-audio-context": "^25.3.77"
    },
    "description": "A demo page to show how to use standardized-audio-context.",
    "devDependencies": {
        "@babel/core": "^7.29.7",
        "@babel/preset-env": "^7.29.7",
        "@commitlint/cli": "^21.2.0",
        "@commitlint/config-angular": "^21.2.0",
        "autoprefixer": "^10.5.2",
        "babel-loader": "^10.1.1",
        "commitizen": "^4.3.2",
        "cssnano": "^8.0.2",
        "cz-conventional-changelog": "^3.3.0",
        "eslint": "^9.39.4",
        "eslint-config-holy-grail": "^63.0.5",
        "globals": "^17.7.0",
        "html-minifier": "^4.0.0",
        "htmlhint": "^1.9.2",
        "husky": "^9.1.7",
        "hyperlink": "^5.0.4",
        "lint-staged": "^17.0.8",
        "postcss": "^8.5.16",
        "postcss-cli": "^11.0.1",
        "prettier": "^3.8.4",
        "rimraf": "^6.1.3",
        "stylelint": "^17.13.0",
        "stylelint-config-holy-grail": "^13.0.2",
        "webpack": "^5.107.2",
        "webpack-cli": "^7.0.3",
        "webpack-dev-server": "^5.2.5"
    },
    "homepage": "https://chrisguttandin.github.io/standardized-audio-context-demo",
    "license": "MIT",
    "main": "src/index.html",
    "name": "standardized-audio-context-demo",
    "private": true,
    "repository": {
        "type": "git",
        "url": "https://github.com/chrisguttandin/standardized-audio-context-demo.git"
    },
    "scripts": {
        "build": "rimraf build/* && html-minifier --config-file config/html-minifier/config.json --file-ext html --input-dir src --output-dir build && npx webpack --config config/webpack/production.js && npx postcss src/**/*.css --base src/ --config config/postcss/ --dir build/",
        "lint": "npm run lint:config && npm run lint:src",
        "lint:config": "eslint --config config/eslint/config.mjs --ext .cjs --ext .js --ext .mjs --report-unused-disable-directives config/",
        "lint:src": "eslint --config config/eslint/src.mjs --ext .js --report-unused-disable-directives src/ && htmlhint --config config/htmlhint/document.json 'src/**/index.html' && npx stylelint 'src/**/*.css' --config config/stylelint/config.json",
        "monitor": "npx webpack server --config config/webpack/development.js",
        "prepare": "husky",
        "test": "npm run lint"
    },
    "version": "1.0.100"
}
